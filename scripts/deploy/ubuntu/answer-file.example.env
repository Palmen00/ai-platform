# Local AI OS installer answer file
# Use with:
#   ./scripts/deploy/ubuntu/installer.sh --non-interactive --answer-file ./scripts/deploy/ubuntu/answer-file.example.env
# or:
#   ./scripts/deploy/ubuntu/configure.sh --answer-file ./scripts/deploy/ubuntu/answer-file.example.env

PROFILE=balanced
OLLAMA_MODE=local
# OLLAMA_BASE_URL=http://10.0.0.20:11434

AUTH_MODE=required
SECURITY_PROFILE=safe
ADMIN_USERNAME=Admin
# Prefer a password file instead of inline ADMIN_PASSWORD
ADMIN_PASSWORD_FILE=/root/local-ai-os-admin-password
# Built-in assistant packs are configured in env by default.

DATA_ROOT=/opt/local-ai-os/data
FRONTEND_PORT=3000
BACKEND_PORT=8000
QDRANT_PORT=6333
# HOSTNAME=ai.internal.example
# PUBLIC_URL_SCHEME=https

OCR_ENABLED=yes
CONNECTOR_FEATURES_ENABLED=yes
