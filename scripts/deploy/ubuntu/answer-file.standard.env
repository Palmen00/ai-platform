# Local AI OS standard Ubuntu profile
# This is the recommended starting point for a single-server install.
# Validate it with:
#   ./scripts/deploy/ubuntu/configure.sh --non-interactive --validate-only --answer-file ./scripts/deploy/ubuntu/answer-file.standard.env

PROFILE=balanced
OLLAMA_MODE=local

AUTH_MODE=required
SECURITY_PROFILE=standard
ADMIN_USERNAME=Admin
ADMIN_PASSWORD_FILE=/tmp/local-ai-os-admin-password
# Default built-in assistant packs: base, local-ai-os, code, reference

DATA_ROOT=/opt/local-ai-os/data
FRONTEND_PORT=3000
BACKEND_PORT=8000
QDRANT_PORT=6333
# PUBLIC_URL_SCHEME=https

OCR_ENABLED=yes
CONNECTOR_FEATURES_ENABLED=yes
