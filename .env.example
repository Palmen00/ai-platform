APP_ENV=dev
APP_NAME=Local AI OS
APP_TIMEZONE=Europe/Stockholm
ASSISTANT_INTELLIGENCE_ENABLED=true
ASSISTANT_BASE_PACKS=base,local-ai-os
ASSISTANT_OPTIONAL_PACKS=code,reference
STARTER_KNOWLEDGE_ENABLED=true
AUTH_ENABLED=false
ADMIN_USERNAME=Admin
ADMIN_PASSWORD_HASH=
# Legacy dev fallback only. Prefer ADMIN_PASSWORD_HASH.
ADMIN_PASSWORD=
ADMIN_SESSION_SECRET=
ADMIN_SESSION_TTL_HOURS=12
ADMIN_LOGIN_MAX_ATTEMPTS=5
ADMIN_LOGIN_LOCKOUT_MINUTES=15
ADMIN_LOGIN_IP_MAX_ATTEMPTS=20
ADMIN_LOGIN_IP_WINDOW_SECONDS=300
ADMIN_LOGIN_GLOBAL_MAX_ATTEMPTS=200
ADMIN_LOGIN_GLOBAL_WINDOW_SECONDS=300
ADMIN_SESSION_COOKIE_NAME=local_ai_admin_session
ADMIN_SESSION_COOKIE_SECURE=false
ADMIN_SESSION_COOKIE_SAMESITE=lax
APP_SECRETS_KEY=
SAFE_MODE=false
LOCAL_CONNECTOR_ALLOWED_ROOTS=
LOW_IMPACT_MODE=false
IDLE_MAINTENANCE_ENABLED=true
IDLE_MAINTENANCE_POLL_SECONDS=45
IDLE_MAINTENANCE_USER_IDLE_SECONDS=240
IDLE_MAINTENANCE_BATCH_SIZE=1
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_DEFAULT_MODEL=llama3.2:3b
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_EMBED_BATCH_SIZE=8
DOCUMENT_LIST_LIMIT_DEFAULT=200
DOCUMENT_UPLOAD_MAX_SIZE_MB=75
SHAREPOINT_TENANT_ID=
SHAREPOINT_CLIENT_ID=
SHAREPOINT_CLIENT_SECRET=
SHAREPOINT_GRAPH_BASE_URL=https://graph.microsoft.com/v1.0
GOOGLE_DRIVE_CLIENT_ID=
GOOGLE_DRIVE_CLIENT_SECRET=
GOOGLE_DRIVE_REFRESH_TOKEN=
GOOGLE_DRIVE_API_BASE_URL=https://www.googleapis.com/drive/v3
GOOGLE_DRIVE_TOKEN_URL=https://oauth2.googleapis.com/token
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION_NAME=document_chunks
RETRIEVAL_LIMIT=4
OCR_ENABLED=true
OCR_LANGUAGE=eng+swe
# Install additional Tesseract language packs such as swe if you want OCR over Swedish-heavy documents.
OCR_RENDER_SCALE=2.5
OCR_MIN_CHARACTERS=80
OCR_PSM_MODES=3,6,11
OCRMYPDF_ENABLED=true
OCRMYPDF_USE_DOCKER=true
OCRMYPDF_DOCKER_IMAGE=local-ai-ocrmypdf:latest
OCRMYPDF_TIMEOUT_SECONDS=180
OCRMYPDF_AUTO_BUILD=true
OCRMYPDF_SKIP_BIG=50
GLINER_ENABLED=true
GLINER_MODEL_ID=urchade/gliner_small-v2.1
GLINER_THRESHOLD=0.4
GLINER_MAX_CHARACTERS=12000
GLINER_WINDOW_SIZE=3200
GLINER_WINDOW_OVERLAP=300
GLINER_MAX_WINDOWS=4
GLINER_BACKFILL_EXISTING=false
UNSTRUCTURED_ENABLED=false
UNSTRUCTURED_MAX_ELEMENTS=800
# TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe
BACKEND_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
